# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_exam_db

# Active LLM Settings (Ollama / OpenAI)
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.2

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# PDF Signing Secret Key (used for cryptographic digital verification)
PDF_SECRET_KEY=super-secret-exam-verification-key-change-this-in-production

# Groq Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-8b-8192
GROQ_TEMPERATURE=0.2

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
OPENROUTER_TEMPERATURE=0.2
